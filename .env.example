# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kbot_new_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Server
BASE_WEBHOOK_URL=https://your-domain.com
WEBHOOK_SECRET=change-me-to-random-32-char-string
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# Kitobxon bot
KITOBXON_BOT_TOKEN=123456:your-bot-token
KITOBXON_ADMIN_IDS=[935795577]
KITOBXON_WEBHOOK_PATH=/kitobxon/webhook

# Logging
LOG_LEVEL=INFO
WEBAPP_JWT_SECRET=change-me-webapp-jwt-secret-32chars
